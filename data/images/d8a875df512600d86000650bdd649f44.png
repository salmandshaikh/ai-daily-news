		<script type="text/javascript">
		jQuery(document).ready(function($) {
			// Function to toggle password visibility
			function togglePasswordVisibility() {
				var passwordInput = $('.elementor-login #password');

				if (passwordInput.attr('type') === 'password') {
					passwordInput.attr('type', 'text');
					$('.elementor-login .eye-icon i').removeClass('fa-eye').addClass('fa-eye-slash');
				} else {
					passwordInput.attr('type', 'password');
					$('.elementor-login .eye-icon i').removeClass('fa-eye-slash').addClass('fa-eye');
				}
			}

			// Append eye icon to the password input field
			var eyeIcon = $('<a href="#" class="eye-icon"><i class="fas fa-eye" aria-hidden="true"></i></a>');
			$('.elementor-login #password').after(eyeIcon);

			// Event listener for the eye icon
			$('.elementor-login .eye-icon').on('click', function(e) {
				e.preventDefault();
				togglePasswordVisibility();
			});
		});
	</script>
		<script type="rocketlazyloadscript">
		document.addEventListener("DOMContentLoaded", function() {
			var products = document.querySelectorAll('.responsive-shop-summary-wrap');

			products.forEach(function(product) {
				var priceElement = product.querySelector('.price');
				var button = product.querySelector('.view_cat_btn');

				// Check if the price element does not exist
				if (!priceElement) {
					button.style.setProperty('background-color', '#A3A3A3', 'important');
				}
			});
		});
	</script>
				<script>
					jQuery(document).ready(function($) {
						$.post('https://www.photowhoa.com/wp-admin/admin-ajax.php', {
							action: "get_dynamic_menu"
						}, function(response) {
							var $container = $("#dynamic-menu-container");
							$container.html(response);

							// Re-init Elementor widgets only inside container
							if (typeof elementorFrontend !== "undefined" && elementorFrontend.hooks) {
								elementorFrontend.hooks.doAction('frontend/element_ready/global', $container);

								//  Also explicitly trigger JetMenu hook
								elementorFrontend.hooks.doAction('frontend/element_ready/jet-mega-menu.default', $container);
							}

							//  Safety: re-init JetMenu directly if available
							if (typeof window.jetMenuPublic !== "undefined" && typeof window.jetMenuPublic.init === "function") {
								window.jetMenuPublic.init();
							}
						});
					});
				</script>
