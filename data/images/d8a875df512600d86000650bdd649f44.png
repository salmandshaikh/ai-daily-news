	<script type="text/javascript">
		jQuery(document).ready(function($) {

			function showStickyBar() {
				var scrollTop = $(window).scrollTop();
				var documentHeight = $(document).height() - $(window).height();
				var scrollPercent = (scrollTop / documentHeight) * 100;
				var windowWidth = window.innerWidth;

				$('.sticky_add_to_cart').each(function() {
					var $bar = $(this);
					var isBothCategories = $bar.hasClass('has-both-categories');

					if (windowWidth < 768) {
						// Mobile view: only show if it has both categories and scrolled > 20%
						if (isBothCategories && scrollPercent > 20) {
							$bar.show();
						} else {
							$bar.hide();
						}
					} else {
						// Tablet & Desktop view: show after 1100px scroll
						if (scrollTop > 700) {
							$bar.show();
						} else {
							$bar.hide();
						}
					}
				});

				$('.sticky_add_to_cart_sticky_add_to_cart').each(function() {
					var $bar = $(this);
					var isBothCategories = $bar.hasClass('has-both-categories');
					var $header = $('header.elementor-location-header.sticky');
					var $header2 = $('.elementor-1069117 .elementor-element.elementor-element-b144369');

					if (windowWidth < 768) {
						// Mobile view: only show if it has both categories and scrolled > 20%
						if (isBothCategories && scrollPercent > 20) {
							$bar.show();

						} else {
							$bar.hide();

						}
					} else {
						// Tablet & Desktop view: show after 1100px scroll
						if (scrollTop > 700) {
							$bar.show();
							$header2.css('box-shadow', 'none');
							$header2.css('border-bottom', '1px solid rgba(219, 219, 219, 1)');
						} else {
							$bar.hide();
							$header2.css('box-shadow', '0px 4px 4px 0px rgba(0, 0, 0, 0.25098039215686274)');
							$header2.css('border-bottom', 'none');
						}
					}
				});

			}

			// Run on scroll and resize
			showStickyBar();
			$(window).on('scroll resize', showStickyBar);
		});
	</script>
		<script>
		var offset = 550;
		jQuery(document).ready(function() {
			jQuery('.elementor-location-header #sticky_block_section').hide();
			jQuery(window).on('load scroll', function() {
				jQuery('.elementor-location-header #sticky_block_section').hide();
				if (jQuery(window).scrollTop() > offset) {
					jQuery('.elementor-location-header #sticky_block_section').css('display', 'block');
					jQuery('.elementor-location-header .elementor-sticky').css('display', 'block');
