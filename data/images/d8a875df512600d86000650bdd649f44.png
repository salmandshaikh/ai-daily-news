	width:100% !important;
}
@font-face {
    font-family: "WooCommerce";
    src: local("&#x263a;"); /* Prevents remote font download */
    font-display: swap !important;
}
@font-face {
    font-family: "WooCommerce";
    src: none !important;
}
/* Fixes for rael lazyloading css */
/* #modal-8f0f0d9 */
.rael-modal-custom.rael-modal-content{
	visibility:hidden !important;
}
.rael-modal-custom.rael-modal-content.rael-show{
	visibility:visible !important;
}
.sticky_add_to_cart_sticky_add_to_cart{
	display:none;
}
/* CSS for Custom product card */
.woocommerce ul.products li.product.custom-card, .woocommerce-page ul.products li.product.custom-card {
  box-shadow: 0px 2.68px 8.49px 0px #C3C3C3;
  border-radius: 6px !important;
}
.woocommerce ul.products li.product.custom-card.masterclass-card , .woocommerce-page ul.products li.product.custom-card.masterclass-card{
	border: 1px solid var(--color-primary-cta);
}

.woocommerce ul.products li.product.custom-card img {
  border-radius: 6px 6px 0 0;
  margin: 0;
}


.woocommerce ul.products li.product.custom-card .card-details{
	padding: 12px;
}
.woocommerce ul.products li.product.custom-card .woocommerce-loop-product__title{
	font-size: var(--pw14-regular-font-size);
  font-weight: var(--font-weight-semibold);
  color: #333333;
  line-height: 20px;
	padding: 0 !important;
}
.woocommerce ul.products li.product.custom-card .card-details .card-category-label {
  font-size: var(--pw12-regular-font-size);
  font-weight: var(  --font-weight-regular);
  color: #333333; 
  line-height: 16px;
  letter-spacing: 2.4px;
	margin-bottom: 10px;
}

.woocommerce ul.products li.product, .woocommerce ul.products li.product.custom-card {
  height: 425px;
}

.pw-is-plus-member .cta-divider-for-non-plus{
	display: none;
}
@media screen and (min-width: 1024px){
	.woocommerce-ordering{
		width: 25%;
    padding-left: 20px;
	} 
	.woocommerce-ordering .dropdown.bootstrap-select.orderby {
		width: 100%;
	}
}
@media screen and (max-width: 1024px){
	.products-wrapper {
		padding: 0 40px;
	}
	.woocommerce-ordering{
		width: 50%;
    padding-left: 15px;
	} 
	.woocommerce-ordering .dropdown.bootstrap-select.orderby {
		width: 100%;
	}
}
@media screen and (max-width: 760px) {
	.products-wrapper {
		padding: 0 40px;
	}
	.woocommerce-ordering, .woocommerce-ordering .dropdown.bootstrap-select.orderby {
		width: 100%;
		padding-left: 0;
	}
}		</style>
